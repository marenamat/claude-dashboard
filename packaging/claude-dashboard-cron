#!/bin/sh
# Refresh Claude Dashboard data every 15 minutes via Alpine's crond.
# Config is read from /etc/claude-dashboard/config.yaml (preferred) or
# /usr/share/claude-dashboard/config.yaml (fallback). generate-data.py
# handles the config search and creates a default if neither file exists.
mkdir -p /var/log/claude-dashboard
exec /usr/bin/python3 /usr/share/claude-dashboard/generate-data.py \
  >>/var/log/claude-dashboard/generate-data.log 2>&1

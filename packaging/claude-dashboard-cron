#!/bin/sh
# Refresh Claude Dashboard data every 15 minutes via Alpine's crond.
# Reads project paths from /usr/share/claude-dashboard/config.yaml
# and writes the updated data to /usr/share/claude-dashboard/www/data.cbor.
# Create config.yaml (see config.yaml.sample in the same directory) before
# enabling this cron job.
[ -f /usr/share/claude-dashboard/config.yaml ] &&
  exec /usr/bin/python3 /usr/share/claude-dashboard/generate-data.py \
    >>/var/log/claude-dashboard/generate-data.log 2>&1

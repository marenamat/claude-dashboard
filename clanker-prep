#!/usr/bin/env python3
# clanker-prep: Prepare Claude context from git and GitHub, decide if invocation needed.
# Prints INVOKE_CLAUDE or NOTHING_TO_DO to stdout.
# All diagnostic output goes to stderr.

import subprocess
import json
import os
import sys
import urllib.request
import urllib.error
from pathlib import Path
from datetime import datetime, timezone

try:
    import yaml
except ImportError:
    print("ERROR: PyYAML not installed (pip install pyyaml)", file=sys.stderr)
    # Fail safe: invoke Claude so it can report the problem
    print("INVOKE_CLAUDE")
    sys.exit(0)

AUTHORIZED_USER = "marenamat"


def run(cmd):
    """Run shell command, return (stdout, stderr, returncode)."""
    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
    return result.stdout.strip(), result.stderr.strip(), result.returncode


def github_api(path):
    """Fetch from GitHub public API. Returns (data, error_string)."""
    url = f"https://api.github.com/{path}"
    headers = {
        "User-Agent": "clanker-prep/1.0",
        "Accept": "application/vnd.github+json",
        "X-GitHub-Api-Version": "2022-11-28",
    }
    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=15) as resp:
            return json.loads(resp.read()), None
    except urllib.error.HTTPError as e:
        return None, f"HTTP {e.code}: {e.reason}"
    except Exception as e:
        return None, str(e)


def get_repo():
    """Detect GitHub repo owner/name from git remotes.
    Tries 'github' first (setup-remotes layout), then falls back to 'origin'.
    """
    for remote in ("github", "origin"):
        out, _, rc = run(f"git remote get-url {remote}")
        if rc != 0 or not out:
            continue
        url = out.strip()
        if url.startswith("https://github.com/"):
            path = url[len("https://github.com/"):]
        elif "github.com:" in url:
            path = url.split("github.com:")[1]
        else:
            continue
        return path.removesuffix(".git").strip("/")
    return None


def get_fetch_remote():
    """Detect the fetch remote name: tries 'github' first (setup-remotes layout), then 'origin'."""
    for remote in ("github", "origin"):
        _, _, rc = run(f"git remote get-url {remote}")
        if rc == 0:
            return remote
    return None


def do_git_maintenance():
    """
    Fetch from the detected remote, fast-forward main, rebase feature branches, prune merged.
    Returns list of action strings for context.
    """
    actions = []

    remote = get_fetch_remote()
    if not remote:
        actions.append("fetch_failed: no usable remote (tried github, origin)")
        return actions

    # Fetch and prune stale remote refs
    out, err, rc = run(f"git fetch {remote} --prune 2>&1")
    if rc != 0:
        print(f"git fetch failed: {out} {err}", file=sys.stderr)
        actions.append(f"fetch_failed: {err}")
    else:
        actions.append("fetched")

    # Fast-forward local main if remote/main is ahead
    local, _, _ = run("git rev-parse main")
    remote_main, _, rc = run(f"git rev-parse {remote}/main")
    if rc != 0:
        actions.append(f"fetch_failed: cannot resolve {remote}/main")
        return actions

    if local != remote_main:
        current, _, _ = run("git branch --show-current")
        run("git checkout main")
        _, err, rc = run(f"git merge --ff-only {remote}/main")
        if rc == 0:
            actions.append("main fast-forwarded")
        else:
            actions.append(f"main ff failed: {err}")
        if current and current != "main":
            run(f"git checkout {current}")

    # Rebase all local branches (except main) onto local main.
    # Local main is always >= remote/main after the fast-forward above,
    # so rebasing onto it avoids replaying already-merged commits.
    # Stash any dirty files so they don't block checkout/rebase (e.g. context
    # files written by an earlier clanker-prep run that Claude hasn't committed yet).
    branches_out, _, _ = run("git branch")
    branches = [line.strip().lstrip("*").strip() for line in branches_out.splitlines()
                if line.strip() and line.strip().lstrip("*").strip() not in ("", "main")]
    if branches:
        current, _, _ = run("git branch --show-current")
        stash_out, _, _ = run("git stash")
        # git stash prints "No local changes to stash" when nothing to stash
        stashed = "No local changes" not in stash_out
        for branch in branches:
            # Skip if origin/main is already an ancestor (branch is up to date)
            _, _, ancestor_rc = run(f"git merge-base --is-ancestor origin/main {branch}")
            if ancestor_rc == 0:
                actions.append(f"up-to-date: {branch}")
                continue
            run(f"git checkout {branch}")
            _, err, rc = run("git rebase main")
            if rc != 0:
                print(f"Rebase of {branch} failed, aborting", file=sys.stderr)
                run("git rebase --abort")
                actions.append(f"rebase_failed: {branch}")
            else:
                actions.append(f"rebased: {branch}")
        # Return to original branch
        restore = current if current else "main"
        run(f"git checkout {restore}")
        if stashed:
            run("git stash pop")

    # Prune local branches fully merged into remote/main
    merged_out, _, _ = run(f"git branch --merged {remote}/main")
    for branch in merged_out.splitlines():
        branch = branch.strip().lstrip("*").strip()
        if branch and branch != "main":
            run(f"git branch -d {branch}")
            actions.append(f"pruned: {branch}")

    return actions


def do_template_merge():
    """
    If a 'claude-base' remote is configured, fetch it and merge new commits
    from the upstream template into main. Returns list of action strings.
    """
    actions = []

    # Check if the remote exists
    _, _, rc = run("git remote get-url claude-base 2>/dev/null")
    if rc != 0:
        return actions  # No template remote configured

    # Fetch from template
    out, err, rc = run("git fetch claude-base 2>&1")
    if rc != 0:
        print(f"claude-base fetch failed: {err}", file=sys.stderr)
        actions.append(f"template_fetch_failed: {err}")
        return actions
    actions.append("template_fetched")

    # Resolve template's main branch
    template_head, _, rc = run("git rev-parse claude-base/main")
    if rc != 0:
        actions.append("template_no_main_branch")
        return actions

    # Skip if template is already an ancestor of local main
    _, _, rc = run(f"git merge-base --is-ancestor claude-base/main main")
    if rc == 0:
        actions.append("template_up_to_date")
        return actions

    # New template commits — try to merge into main
    current, _, _ = run("git branch --show-current")
    run("git checkout main")
    _, err, rc = run("git merge --no-edit claude-base/main 2>&1")
    if rc == 0:
        actions.append("template_merged")
    else:
        run("git merge --abort 2>/dev/null || true")
        actions.append(f"template_merge_failed: {err}")
        print(f"Template merge failed: {err}", file=sys.stderr)
    if current and current != "main":
        run(f"git checkout {current}")

    return actions


def fetch_issues(repo):
    """Fetch open issues + comments from GitHub. Returns list of issue dicts."""
    issues, err = github_api(f"repos/{repo}/issues?state=open&per_page=50")
    if err:
        print(f"Issues fetch error: {err}", file=sys.stderr)
        return None, err

    authorized = [i for i in issues if i["user"]["login"] == AUTHORIZED_USER]
    result = []
    for i in authorized:
        entry = {
            "number": i["number"],
            "title": i["title"],
            "author": i["user"]["login"],
            "body": i["body"] or "",
            "created_at": i["created_at"],
            "labels": [lb["name"] for lb in i.get("labels", [])],
            "comments": [],
        }
        comments, cerr = github_api(f"repos/{repo}/issues/{i['number']}/comments")
        if cerr:
            print(f"Comments fetch error for #{i['number']}: {cerr}", file=sys.stderr)
        elif comments:
            entry["comments"] = [
                {"author": c["user"]["login"], "body": c["body"]}
                for c in comments
            ]
        result.append(entry)
    return result, None


def fetch_pipelines(repo):
    """Fetch recent workflow runs from GitHub. Returns list of run dicts."""
    data, err = github_api(f"repos/{repo}/actions/runs?per_page=20")
    if err:
        print(f"Pipeline fetch error: {err}", file=sys.stderr)
        return None, err
    runs = data.get("workflow_runs", [])
    return [
        {
            "id": r["id"],
            "name": r["name"],
            "status": r["status"],
            "conclusion": r["conclusion"],
            "branch": r["head_branch"],
            "created_at": r["created_at"],
        }
        for r in runs
    ], None


def main():
    selfdir = Path(__file__).parent.resolve()
    os.chdir(selfdir)

    context_dir = selfdir / "claude" / "context"
    context_dir.mkdir(parents=True, exist_ok=True)

    now = datetime.now(timezone.utc).isoformat()
    reasons = []

    # --- Git maintenance ---
    print("Running git maintenance...", file=sys.stderr)
    git_actions = do_git_maintenance()
    print(f"Git actions: {git_actions}", file=sys.stderr)

    # --- Template merge ---
    print("Checking upstream template (claude-base)...", file=sys.stderr)
    template_actions = do_template_merge()
    print(f"Template actions: {template_actions}", file=sys.stderr)
    git_actions.extend(template_actions)

    # Use 'git branch' and strip the '* ' marker from the current branch
    branches_out, _, _ = run("git branch")
    existing_branches = {line.strip().lstrip("*").strip() for line in branches_out.splitlines() if line.strip()}

    git_ctx = {
        "recorded_at": now,
        "maintenance_actions": git_actions,
        "branches": sorted(existing_branches),
    }
    with open(context_dir / "git_status.yaml", "w") as f:
        yaml.dump(git_ctx, f, default_flow_style=False, allow_unicode=True)

    # Rebase failures need Claude to resolve conflicts
    for action in git_actions:
        if action.startswith("rebase_failed:") or action.startswith("template_merge_failed:"):
            reasons.append(action)

    # --- Detect repo ---
    repo = get_repo()
    if not repo:
        print("Cannot detect GitHub repo from remotes (tried: github, origin)", file=sys.stderr)
        reasons.append("cannot detect GitHub repo - manual check needed")

    # --- Issues ---
    issues_ctx = {"fetched_at": now, "repo": repo, "issues": []}
    if repo:
        print(f"Fetching issues for {repo}...", file=sys.stderr)
        issues, err = fetch_issues(repo)
        if err:
            reasons.append(f"issue fetch failed: {err}")
        elif issues is not None:
            issues_ctx["issues"] = issues
            for issue in issues:
                num = issue["number"]
                # If no branch references this issue number, it's unhandled
                if not any(str(num) in b for b in existing_branches):
                    reasons.append(f"unhandled issue #{num}: {issue['title']}")

    with open(context_dir / "github_issues.yaml", "w") as f:
        yaml.dump(issues_ctx, f, default_flow_style=False, allow_unicode=True)

    # --- Pipelines ---
    pipeline_ctx = {"fetched_at": now, "repo": repo, "runs": []}
    if repo:
        print("Fetching pipeline results...", file=sys.stderr)
        runs, err = fetch_pipelines(repo)
        if err:
            print(f"Pipeline fetch skipped: {err}", file=sys.stderr)
        elif runs is not None:
            pipeline_ctx["runs"] = runs
            for r in runs:
                if r["conclusion"] in ("failure", "action_required") and r["branch"] == "main":
                    reasons.append(f"pipeline failure on main: {r['name']}")

    with open(context_dir / "pipeline_results.yaml", "w") as f:
        yaml.dump(pipeline_ctx, f, default_flow_style=False, allow_unicode=True)

    # --- Decision ---
    if reasons:
        print(f"Invoking Claude. Reasons: {reasons}", file=sys.stderr)
        print("INVOKE_CLAUDE")
    else:
        print("Nothing actionable. Skipping Claude.", file=sys.stderr)
        print("NOTHING_TO_DO")


if __name__ == "__main__":
    main()

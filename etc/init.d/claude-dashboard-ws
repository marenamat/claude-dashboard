#!/bin/sh
### BEGIN INIT INFO
# Provides:          claude-dashboard-ws
# Required-Start:    $network $local_fs
# Required-Stop:     $network $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Claude Dashboard WebSocket server
# Description:       WebSocket server for Claude Dashboard live reload (issue #9).
#                    Watches www/data.cbor and clanker.lock files; notifies
#                    connected browsers so they reload automatically.
### END INIT INFO

# ---- Adjust these variables for your installation ----
INSTALLDIR=/home/maria/claude/claude-dashboard
PYTHON=/usr/bin/python3
WSSCRIPT="$INSTALLDIR/ws-server.py"
PIDFILE=/run/claude-dashboard-ws.pid
LOGDIR=/var/log/claude-dashboard
LOGFILE="$LOGDIR/ws-server.log"
# -------------------------------------------------------

NAME=claude-dashboard-ws
DESC="Claude Dashboard WebSocket server"

set -e
. /lib/lsb/init-functions

do_start() {
  mkdir -p "$LOGDIR"
  log_daemon_msg "Starting $DESC" "$NAME"
  if start-stop-daemon --start --quiet \
      --pidfile "$PIDFILE" --make-pidfile \
      --background --no-close \
      --exec "$PYTHON" -- "$WSSCRIPT" \
      >> "$LOGFILE" 2>&1; then
    log_end_msg 0
  else
    log_end_msg 1
  fi
}

do_stop() {
  log_daemon_msg "Stopping $DESC" "$NAME"
  start-stop-daemon --stop --quiet --oknodo \
    --pidfile "$PIDFILE" \
    --retry=TERM/30/KILL/5
  log_end_msg $?
  rm -f "$PIDFILE"
}

case "$1" in
  start)
    do_start
    ;;
  stop)
    do_stop
    ;;
  restart)
    do_stop
    do_start
    ;;
  status)
    status_of_proc -p "$PIDFILE" "$PYTHON" "$NAME" && exit 0 || exit $?
    ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}" >&2
    exit 1
    ;;
esac

exit 0

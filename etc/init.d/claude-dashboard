#!/bin/sh
### BEGIN INIT INFO
# Provides:          claude-dashboard
# Required-Start:    $network $local_fs
# Required-Stop:     $network $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Claude Dashboard HTTP server
# Description:       Serves Claude Dashboard static files over HTTP on the
#                    local network so the nginx proxy machine can reach it.
### END INIT INFO

# ---- Adjust these variables for your installation ----
INSTALLDIR=/home/maria/claude/claude-dashboard
NGINX=/usr/sbin/nginx
CONF="$INSTALLDIR/nginx/clanker.conf"
PIDFILE=/run/claude-dashboard.pid
LOGDIR=/var/log/claude-dashboard

NAME=claude-dashboard
DESC="Claude Dashboard HTTP server"
# -------------------------------------------------------

set -e

. /lib/lsb/init-functions

do_start() {
  # Create log dir if missing.
  mkdir -p "$LOGDIR"
  # Validate config before starting.
  "$NGINX" -t -c "$CONF" > /dev/null 2>&1 || {
    log_failure_msg "$NAME: config test failed (run: nginx -t -c $CONF)"
    exit 1
  }
  log_daemon_msg "Starting $DESC" "$NAME"
  if start-stop-daemon --start --quiet \
      --pidfile "$PIDFILE" --exec "$NGINX" --test > /dev/null; then
    start-stop-daemon --start --quiet \
      --pidfile "$PIDFILE" --exec "$NGINX" \
      -- -c "$CONF"
    log_end_msg 0
  else
    log_end_msg 1
    echo "$NAME is already running" >&2
  fi
}

do_stop() {
  log_daemon_msg "Stopping $DESC" "$NAME"
  start-stop-daemon --stop --quiet --oknodo \
    --pidfile "$PIDFILE" --exec "$NGINX" \
    --retry=TERM/30/KILL/5
  log_end_msg $?
  rm -f "$PIDFILE"
}

do_reload() {
  log_daemon_msg "Reloading $DESC configuration" "$NAME"
  start-stop-daemon --stop --quiet \
    --pidfile "$PIDFILE" --exec "$NGINX" \
    --signal HUP
  log_end_msg $?
}

case "$1" in
  start)
    do_start
    ;;
  stop)
    do_stop
    ;;
  reload)
    do_reload
    ;;
  restart)
    do_stop
    do_start
    ;;
  status)
    status_of_proc -p "$PIDFILE" "$NGINX" "$NAME" && exit 0 || exit $?
    ;;
  *)
    echo "Usage: $0 {start|stop|reload|restart|status}" >&2
    exit 1
    ;;
esac

exit 0

#!/bin/bash

set -e

self=$(readlink -f "$0")
selfdir=$(dirname "$self")

if [ "x$1" == "x--force" ]; then
  force=true
else
  force=false
fi

cd "$selfdir"

echo "===========" >> clanker.log
date >> clanker.log

touch clanker.lock

# Used to signal a restart request from inside the flock subshell.
restart_flag="$selfdir/.clanker-restart-$$"

(
  flock -n 200 || { echo "Clanker probably still runs." >>clanker.log; exit 0; }

  # Snapshot key runner/definition files before git maintenance.
  # If any change after prep (due to git fast-forward), we restart so we run
  # the updated code rather than spending tokens on a stale version.
  _snap() { md5sum "$selfdir/clanker-run" "$selfdir/clanker-prep" "$selfdir/CLAUDE.md" 2>/dev/null || true; }
  before_snap=$(_snap)

  # Run prep: does git maintenance, downloads issues/pipelines, writes context.
  # Prints INVOKE_CLAUDE or NOTHING_TO_DO.
  decision=$(python3 "$selfdir/clanker-prep" 2>>clanker.log)

  # If runner or definition files changed, signal a restart and stop here.
  after_snap=$(_snap)
  if [ "$before_snap" != "$after_snap" ]; then
    echo "Runner files updated by git, restarting..." >>clanker.log
    touch "$restart_flag"
    exit 0
  fi

  echo "Prep decision: $decision" >>clanker.log

  # Record start time; defaults used when claude is not invoked
  start_time=$(date -u +"%Y-%m-%dT%H:%M:%S+00:00")
  invoked=false
  exit_code=-1
  tmp_out=$(mktemp)
  current_json="$selfdir/clanker-current.json"
  watcher_script=$(mktemp --suffix=.py)
  watcher_pid=""

  # Ensure cleanup on any exit (normal, error, or signal).
  # Kills background watcher, removes temp files, and deletes the live
  # session marker so the dashboard never sees a stale "running" record.
  cleanup() {
    [ -n "$watcher_pid" ] && { kill "$watcher_pid" 2>/dev/null || true; wait "$watcher_pid" 2>/dev/null || true; }
    rm -f "$watcher_script" "$tmp_out" "$current_json" 2>/dev/null || true
  }
  trap cleanup EXIT

  if $force || [ "$decision" = "INVOKE_CLAUDE" ]; then
    invoked=true

    # Write clanker-current.json to signal a live session to the dashboard.
    # Fields: pid (for stale-detection), project, log_file (dashboard can tail
    # this for live stream-json lines), and live token/cost counters.
    python3 - "$selfdir" "$BASHPID" "$start_time" "$tmp_out" "$current_json" "${CLANKER_TASK:-}" <<'PYEOF'
import sys, json
selfdir, pid, start, log_file, out_path, task = sys.argv[1:]
record = {
    "pid":        int(pid),
    "start":      start,
    "project":    selfdir,
    "log_file":   log_file,
    "status":     "running",
    "tokens_in":  0,
    "tokens_out": 0,
    "cost_usd":   None,
}
if task:
    record["task"] = task
with open(out_path, "w") as f:
    json.dump(record, f)
    f.write("\n")
PYEOF

    # Write background watcher script: tails tmp_out as Claude writes to it and
    # updates token/cost fields in clanker-current.json in-place every 2 s.
    cat >"$watcher_script" <<'PYEOF'
#!/usr/bin/env python3
import sys, json, time

log_file, current_json = sys.argv[1:]
pos = 0

while True:
    try:
        with open(log_file) as f:
            f.seek(pos)
            lines = f.readlines()
            pos = f.tell()
        for line in lines:
            s = line.strip()
            if not s:
                continue
            try:
                obj = json.loads(s)
                t = obj.get("type")
                updates = {}
                if t == "assistant":
                    # usage may be nested under message.usage
                    usage = (obj.get("message") or {}).get("usage") or obj.get("usage") or {}
                    if usage.get("input_tokens") is not None:
                        updates["tokens_in"] = usage["input_tokens"]
                    if usage.get("output_tokens") is not None:
                        updates["tokens_out"] = usage["output_tokens"]
                elif t == "result":
                    usage = obj.get("usage") or {}
                    if usage.get("input_tokens") is not None:
                        updates["tokens_in"] = usage["input_tokens"]
                    if usage.get("output_tokens") is not None:
                        updates["tokens_out"] = usage["output_tokens"]
                    if obj.get("cost_usd") is not None:
                        updates["cost_usd"] = obj["cost_usd"]
                    updates["status"] = "done"
                if updates:
                    try:
                        with open(current_json) as cf:
                            rec = json.load(cf)
                        rec.update(updates)
                        with open(current_json, "w") as cf:
                            json.dump(rec, cf)
                            cf.write("\n")
                    except Exception:
                        pass
            except Exception:
                pass
    except FileNotFoundError:
        pass
    except Exception:
        pass
    time.sleep(2)
PYEOF
    python3 "$watcher_script" "$tmp_out" "$current_json" &
    watcher_pid=$!

    # Run with stream-json so we can extract cost/token data.
    # CLANKER_PROMPT can be overridden by wrapper scripts (e.g. clanker-housekeeping).
    prompt="${CLANKER_PROMPT:-proceed as the workflow specifies in CLAUDE.md}"
    ~/.local/bin/claude \
      -n "$selfdir" \
      --no-session-persistence \
      --output-format=stream-json \
      --verbose \
      "$prompt" \
      </dev/null >"$tmp_out" 2>&1 || exit_code=$?
    exit_code=${exit_code:-0}

    # Stop the background watcher now that Claude has exited
    kill "$watcher_pid" 2>/dev/null || true
    wait "$watcher_pid" 2>/dev/null || true
    watcher_pid=""

    # Append raw stream output to log (=== header and date were written above)
    cat "$tmp_out" >>clanker.log
    case "$exit_code" in
      0)  date >>clanker.log ;;
      *)  date >>clanker.log
          echo "exit status $exit_code" >>clanker.log ;;
    esac
  fi

  # Append one JSON record to clanker-runs.jsonl
  end_time=$(date -u +"%Y-%m-%dT%H:%M:%S+00:00")
  python3 - "$start_time" "$end_time" "$invoked" "$exit_code" "$tmp_out" \
    >>"$selfdir/clanker-runs.jsonl" <<'PYEOF' || true
import sys, json, re
from datetime import datetime, timezone

start, end, invoked_str, exit_code_str, tmp_path = sys.argv[1:]
invoked = invoked_str == "true"
exit_code = int(exit_code_str)

# "You've hit your limit · resets 11pm" or "resets at 11pm" etc.
RE_LIMIT_RESET = re.compile(
    r"you.?ve hit your limit.*?reset\w*\s+(?:at\s+)?([^\s.,\n]+)", re.IGNORECASE)

cost_usd = None
tokens_in = None
tokens_out = None
limit_hit = False
limit_reset = None
last_result = None
log_lines = []

try:
    with open(tmp_path) as f:
        log_lines = f.readlines()
    for line in log_lines:
        s = line.strip()
        # Text fallback for rate limit detection.
        # May match historical context embedded in user-type messages;
        # we clear it below if the result record shows success.
        if re.search(r"you.ve hit your limit", s, re.I):
            limit_hit = True
            m = RE_LIMIT_RESET.search(s)
            if m and limit_reset is None:
                limit_reset = m.group(1)
        try:
            obj = json.loads(s)
            t = obj.get("type")
            if t == "result":
                last_result = obj
                cost_usd = obj.get("cost_usd")
                usage = obj.get("usage", {})
                tokens_in = usage.get("input_tokens")
                tokens_out = usage.get("output_tokens")
                # Reliable rate-limit detection from structured result
                err_msg = str(obj.get("result") or obj.get("error", ""))
                if obj.get("subtype") == "error" and re.search(r"limit", err_msg, re.I):
                    limit_hit = True
                m = RE_LIMIT_RESET.search(err_msg)
                if m and limit_reset is None:
                    limit_reset = m.group(1)
            elif t == "rate_limit_event":
                # rate_limit_event is the authoritative limit signal
                limit_hit = True
                if limit_reset is None:
                    resets_at = (obj.get("rate_limit_info") or {}).get("resetsAt")
                    if resets_at:
                        try:
                            dt = datetime.fromtimestamp(int(resets_at), tz=timezone.utc)
                            limit_reset = dt.strftime("%H:%M UTC")
                        except Exception:
                            pass
        except Exception:
            pass
except Exception:
    pass

# If run completed successfully, clear any spurious limit_hit set by the
# text fallback (which may have matched old context passed as input to Claude).
if last_result is not None and not last_result.get("is_error", True):
    limit_hit = False

excerpt = "".join(log_lines[-40:]).rstrip("\n") if log_lines else ""

record = {
    "start":        start,
    "end":          end,
    "invoked":      invoked,
    "exit_code":    exit_code,
    "cost_usd":     cost_usd,
    "tokens_in":    tokens_in,
    "tokens_out":   tokens_out,
    "limit_hit":    limit_hit,
    "limit_reset":  limit_reset,
    "log_excerpt":  excerpt,
}
print(json.dumps(record))
PYEOF

  # cleanup trap handles rm of tmp_out, watcher_script, and current_json

) 200>clanker.lock

# The flock subshell has released the lock. If a restart was requested,
# re-exec with the updated runner binary.
if [ -f "$restart_flag" ]; then
  rm -f "$restart_flag"
  exec "$self" "$@"
fi

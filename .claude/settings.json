{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(curl *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(pip3 *:*)",
      "Bash(apk list:*)",
      "Bash(apk search:*)",
      "Bash(cargo *)"
    ],
    "deny": [
      "Bash(npm *)"
    ]
  }
}
